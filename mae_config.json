  "default_xpaths": {
        "product_title":       { "by": "XPATH", "value": ".//span[@id='productTitle']" },
        "number_of_ratings":   { "by": "XPATH", "value": "//span[@id='acrCustomerReviewText']" },
        "stock":               { "by": "XPATH", "value": "//div[@id='availability']" },
        "rating_stars":        { "by": "XPATH", "value": "//span[@class='a-icon-alt']" },
        "brand":               { "by": "ID",    "value": "bylineInfo" },
        "merchant":            { "by": "ID",    "value": "sellerProfileTriggerId" },
        "product_category_gl": { "by": "ID",    "value": "productCategory" },
        "product_category":    { "by": "ID",    "value": "wayfinding-breadcrumbs_feature_div" },
        "product_category_links": { "by": "XPATH", "value": "//div[@id='wayfinding-breadcrumbs_feature_div']//a" },
        "asin_product_page":   { "by": "XPATH", "value": "//div[@id='prodDetails']//tr[th[contains(text(), 'ASIN')]]/td" },
        "features":            { "by": "XPATH", "value": "//*[@id='feature-bullets']/ul/li/span" },
        "price_container":     { "by": "CSS_SELECTOR", "value": "#corePriceDisplay_desktop_feature_div" },
        "price_whole":         { "by": "CSS_SELECTOR", "value": "span.a-price-whole" },
        "price_fraction":      { "by": "CSS_SELECTOR", "value": "span.a-price-fraction" },
        "list_price":          { "by": "XPATH", "value": "//span[contains(@class, 'a-price a-text-price') and @data-a-strike='true']" },
        "badge_ac_primary":    { "by": "XPATH", "value": "//span[@class='ac-badge-text-primary ac-white']" },
        "badge_ac_secondary":  { "by": "XPATH", "value": "//span[@class='ac-badge-text-secondary ac-orange']" },
        "badge_ac_for":        { "by": "XPATH", "value": "//span[@class='ac-for-text']" },
        "badge_bs_icon":       { "by": "XPATH", "value": "//i[@class='a-icon a-icon-addon p13n-best-seller-badge']" },
        "badge_bs_cat":        { "by": "XPATH", "value": "//span[@class='cat-link']" },
        "limited_time_deal":   { "by": "ID",    "value": "dealBadgeSupportingText" },
        "prime_day_deal":      { "by": "XPATH", "value": "//span[@class='pep-pday-badge']" },
        "ped_secondary":       { "by": "ID",    "value": "primeExclusivePricingMessage" },
        "prev_month_qty":      { "by": "XPATH", "value": "//*[@id='social-proofing-faceout-title-tk_bought']/span[1]" },
        "freq_returned_badge": { "by": "XPATH", "value": "//*[@id='NEW_1_nostos_badge']/div/div/div/h5/p/span" },
        "deal":                { "by": "XPATH", "value": "//span[@class='a-size-base gb-accordion-active a-text-bold']" },
        "coupon":              { "by": "CSS_SELECTOR", "value": ".promoPriceBlockMessage" },
        "zip_container":       { "by": "CSS_SELECTOR", "value": "#glow-ingress-line2" },
        "bsr_container":       { "by": "ID", "value": "productDetails_detailBullets_sections1" },
        "color_name": [
          { "by": "CSS_SELECTOR", "value": "#inline-twister-expanded-dimension-text-color_name" },
          { "by": "XPATH", "value": "//*[@id='inline-twister-expanded-dimension-text-color_name']" },
          { "by": "CSS_SELECTOR", "value": "#variation_color_name > div.a-row > span" },
          { "by": "XPATH", "value": "//*[@id='variation_color_name']/div[1]/span" }
        ],
        "size_name": [
          { "by": "CSS_SELECTOR", "value": "#inline-twister-expanded-dimension-text-size_name" },
          { "by": "XPATH", "value": "//*[@id='inline-twister-expanded-dimension-text-size_name']" },
          { "by": "CSS_SELECTOR", "value": "#variation_size_name > div.a-row > span" },
          { "by": "XPATH", "value": "//*[@id='variation_size_name']/div[1]/span" }
        ]
      },

